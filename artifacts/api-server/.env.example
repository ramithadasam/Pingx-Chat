# PingX Chat API server — environment variables
# Copy this file: cp .env.example .env
# Then fill in the values below.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development

# ── CORS ─────────────────────────────────────────────────────────────────────
# Local dev: allow Vite frontend. Production: set to your Vercel/custom domain.
CORS_ORIGIN=http://localhost:5173
# Production example:
# CORS_ORIGIN=https://pingx.vercel.app

# ── Database (PostgreSQL + Drizzle) ──────────────────────────────────────────
# Free PostgreSQL: https://neon.tech (sign up → New project → copy connection string)
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=30d

# ── Cloudinary (optional — media upload endpoints return 503 if not set) ─────
# Free account: https://cloudinary.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
