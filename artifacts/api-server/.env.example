# PingX Chat API server — environment variables
# Copy this file to .env and fill in real values for local development.
# In Replit, set these under the Secrets tab instead of committing a .env file.

# --- Server ---
PORT=8080
NODE_ENV=development

# Comma-separated list is NOT supported; cors() accepts a single origin,
# an array, or "*". For local dev with the Vite frontend (see
# artifacts/pingx, port 21913 per .replit-artifact/artifact.toml):
CORS_ORIGIN=http://localhost:21913

# --- Database (Postgres + Drizzle) ---
# postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pingx

# --- JWT ---
# Use a long, random string in production (e.g. `openssl rand -hex 32`)
JWT_SECRET=change-me-to-a-long-random-string
# Examples: "15m", "1h", "7d", "30d"
JWT_EXPIRES_IN=30d

# --- Cloudinary (avatars + chat media) ---
# From your Cloudinary dashboard: https://console.cloudinary.com/
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Logging ---
LOG_LEVEL=info
