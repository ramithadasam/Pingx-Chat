# PingX Chat frontend — environment variables
# Copy this file to .env for local development.
#
# In production the frontend is served as static files behind the same
# reverse proxy that routes /api/* (REST + Socket.IO) to the API server,
# so VITE_API_BASE_URL should be left unset (or empty) in production.

# Local dev only: point REST + Socket.IO calls at the API server, which
# runs on a different port than the Vite dev server (21913).
# Match this to the API server's PORT (see artifacts/api-server/.env.example).
VITE_API_BASE_URL=http://localhost:8080
